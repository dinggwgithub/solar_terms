{
    "swagger": "2.0",
    "info": {
        "description": "功能丰富的Go语言科学计算库，提供天文计算、历法转换、方程求解等多种科学计算功能。",
        "title": "科学计算工具集 API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/calculate": {
            "post": {
                "description": "执行各种类型的科学计算",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "科学计算"
                ],
                "summary": "执行科学计算",
                "parameters": [
                    {
                        "type": "string",
                        "description": "会话ID，用于保持计算参数一致性，不传则自动生成",
                        "name": "session_id",
                        "in": "query"
                    },
                    {
                        "description": "计算请求参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.CalculationRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.CalculationResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/calculate-fixed": {
            "post": {
                "description": "修复版科学计算接口，修复了星宿、农历、干支、儒略日等科学错误",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "科学计算"
                ],
                "summary": "修复版科学计算接口",
                "parameters": [
                    {
                        "type": "string",
                        "description": "会话ID",
                        "name": "session_id",
                        "in": "query"
                    },
                    {
                        "description": "计算请求参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.CalculationRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.CalculationResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/calculator-info": {
            "get": {
                "description": "获取指定计算器的详细信息",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "计算器管理"
                ],
                "summary": "获取计算器信息",
                "parameters": [
                    {
                        "type": "string",
                        "description": "计算类型: solar_term, ganzhi, astronomy, starting_age, lunar, planet, star, sunrise_sunset, moon_phase",
                        "name": "calculation",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.CalculatorInfoResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/health": {
            "get": {
                "description": "健康检查接口",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统"
                ],
                "summary": "健康检查",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.HealthResponse"
                        }
                    }
                }
            }
        },
        "/api/solver/compare": {
            "post": {
                "description": "对比原始缺陷响应与修复后响应的结构化差异",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "科学计算"
                ],
                "summary": "响应对比接口",
                "parameters": [
                    {
                        "description": "计算请求参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.CalculationRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.CompareResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/system-info": {
            "get": {
                "description": "获取系统支持的完整信息",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统"
                ],
                "summary": "获取系统信息",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.SystemInfoResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.CalculationResponse": {
            "type": "object",
            "properties": {
                "calculation": {
                    "type": "string"
                },
                "result": {},
                "session_id": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                },
                "timestamp": {
                    "type": "string"
                },
                "warnings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "api.CalculatorInfoResponse": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "api.CompareResponse": {
            "type": "object",
            "properties": {
                "calculation": {
                    "type": "string"
                },
                "differences": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.DifferenceItem"
                    }
                },
                "fix_rate": {
                    "type": "string"
                },
                "fixed": {
                    "type": "object",
                    "additionalProperties": true
                },
                "fixed_count": {
                    "type": "integer"
                },
                "original": {
                    "type": "object",
                    "additionalProperties": true
                },
                "success": {
                    "type": "boolean"
                },
                "timestamp": {
                    "type": "string"
                },
                "total_fields": {
                    "type": "integer"
                }
            }
        },
        "api.DifferenceItem": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "field": {
                    "type": "string"
                },
                "field_cn": {
                    "type": "string"
                },
                "fixed": {
                    "type": "boolean"
                },
                "fixed_value": {
                    "type": "string"
                },
                "original_value": {
                    "type": "string"
                }
            }
        },
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "error": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "api.HealthResponse": {
            "type": "object",
            "properties": {
                "build_time": {
                    "type": "string",
                    "example": "2024-01-01T12:00:00Z"
                },
                "status": {
                    "type": "string",
                    "example": "healthy"
                },
                "time": {
                    "type": "string",
                    "example": "2024-01-01T12:00:00Z"
                },
                "version": {
                    "type": "string",
                    "example": "1.0.0"
                }
            }
        },
        "api.SystemInfoResponse": {
            "type": "object",
            "properties": {
                "supported_calculations": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "total_calculators": {
                    "type": "integer"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "models.CalculationRequest": {
            "type": "object",
            "required": [
                "calculation"
            ],
            "properties": {
                "calculation": {
                    "description": "璁＄畻绫诲瀷",
                    "type": "string"
                },
                "day": {
                    "description": "鏃ユ湡",
                    "type": "integer"
                },
                "days_from_term": {
                    "description": "璺濊妭姘斿ぉ鏁?",
                    "type": "integer"
                },
                "hour": {
                    "description": "灏忔椂",
                    "type": "integer"
                },
                "minute": {
                    "description": "鍒嗛挓",
                    "type": "integer"
                },
                "month": {
                    "description": "鏈堜唤",
                    "type": "integer"
                },
                "params": {
                    "description": "璁＄畻鍙傛暟锛堟牸寮?锛?"
                },
                "second": {
                    "description": "绉?",
                    "type": "integer"
                },
                "solar_date": {
                    "description": "闃冲巻鏃ユ湡",
                    "type": "string"
                },
                "target_longitude": {
                    "description": "鐩爣榛勭粡",
                    "type": "number"
                },
                "term_index": {
                    "description": "鑺傛皵绱㈠紩 (0-23)",
                    "type": "integer"
                },
                "year": {
                    "description": "鐩存帴鍙傛暟锛堟牸寮?锛?",
                    "type": "integer"
                }
            }
        }
    }
}